{
  "type": "browser",
  "url": "http://localhost:3000/register",
  "name": "Register Test Account",
  "description": "Register a new test user and verify redirect to dashboard",
  "setup_steps": [
    {
      "action": "wait",
      "selector": "input[name='email']"
    },
    {
      "action": "type",
      "selector": "input[name='name']",
      "value": "Test User"
    },
    {
      "action": "type",
      "selector": "input[name='email']",
      "value": "test@example.com"
    },
    {
      "action": "type",
      "selector": "input[name='password']",
      "value": "testpass123"
    },
    {
      "action": "click",
      "selector": "button[type='submit']"
    },
    {
      "action": "wait_ms",
      "wait_ms": 3000
    }
  ],
  "assertions": [
    {
      "type": "url_contains",
      "expected": "/dashboard",
      "description": "Should redirect to dashboard after register",
      "purpose": "Verify auth flow completes and user lands on dashboard"
    },
    {
      "type": "exists",
      "selector": "body",
      "description": "Page has content",
      "purpose": "Basic page render check"
    }
  ]
}